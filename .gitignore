# Vendor directory
vendor/

# Generated by Cargo
# will have compiled files and executables
debug/
target/
bin/

# Remove Cargo.lock from gitignore if creating an executable, leave it for libraries
# More information here https://doc.rust-lang.org/cargo/guide/cargo-toml-vs-cargo-lock.html
Cargo.lock

# These are backup files generated by rustfmt
**/*.rs.bk

# MSVC Windows builds of rustc generate these, which store debugging information
*.pdb

# Act local environment file
.env.local
.env

# Local config file (may contain secrets — use config.example.toml as template)
config.toml

# Act artifacts directory
/tmp/act-artifacts

# Generated code from buf
/api/gen/

# IDE files
.vscode/
.idea/
*.swp
*.swo

# OS generated files
.DS_Store
.DS_Store?
._*
.Spotlight-V100
.Trashes
ehthumbs.db
Thumbs.db

.devbox/

# Lima VM
.lima/

tmp-*/

# Docs build outputs
docs/book/
public/

# Local git worktrees (in-repo)
.worktrees/

.cargo/

# Node (Playwright screenshot script)
node_modules/
package-lock.json
desktop/build/
desktop/artifacts/
desktop/.electrobun/

# Python caches
__pycache__/
*.pyc
*.egg-info/

# Helm chart dependencies (downloaded via helm dependency build)
deploy/helm/*/charts/
deploy/helm/*/Chart.lock

.pytest_cache/
.venv/
.worktrees/