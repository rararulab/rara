# Yunara Store Migration Tasks
#
# This crate uses diesel_migrations::embed_migrations! at runtime. These
# tasks are optional helpers if you have diesel_cli installed.

DATABASE_URL := env('DATABASE_URL', 'sqlite://./rara.db')
MIGRATION_DIRECTORY := env('MIGRATION_DIRECTORY', '../../rara-model/migrations')

[group("📒 Help")]
[private]
default:
    @just --list

# Create a new migration
migrate-create name:
    diesel migration generate --migration-dir {{MIGRATION_DIRECTORY}} {{name}}

alias mc := migrate-create

# Run all pending migrations
migrate:
    DATABASE_URL={{DATABASE_URL}} diesel migration run --migration-dir {{MIGRATION_DIRECTORY}}

# Revert the most recent migration
migrate-revert:
    DATABASE_URL={{DATABASE_URL}} diesel migration revert --migration-dir {{MIGRATION_DIRECTORY}}
