# =============================================================================
# docker-compose environment variables
# Copy to .env and adjust as needed:  cp .env.example .env
# =============================================================================

# PostgreSQL
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
POSTGRES_DB=rara
POSTGRES_PORT=5432

# MinIO (S3-compatible object storage)
MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
MINIO_BUCKET=rara
MINIO_API_PORT=9000
MINIO_CONSOLE_PORT=9001

# ChromaDB (vector store)
CHROMA_PORT=8000

# Crawl4AI (web crawler)
CRAWL4AI_PORT=11235

# Mem0 REST API
MEM0_PORT=8888
MEM0_OPENAI_API_KEY=

# Memos (note service)
MEMOS_PORT=5230
MEMOS_PG_USER=memos
MEMOS_PG_PASSWORD=memos
MEMOS_PG_DB=memos

# Hindsight (4-network memory)
HINDSIGHT_PORT=8100
HINDSIGHT_PG_USER=hindsight
HINDSIGHT_PG_PASSWORD=hindsight
HINDSIGHT_PG_DB=hindsight

# Consul (config center)
CONSUL_PORT=8500

# App (backend)
APP_HTTP_PORT=25555
APP_GRPC_PORT=50051

# Web (frontend)
WEB_PORT=8080
