# --------------------------------------------------------------------------
# Consul KV
# --------------------------------------------------------------------------

[doc("seed Consul KV with infrastructure config (database, minio, chroma)")]
[group("🔧 Consul")]
seed-consul:
    #!/usr/bin/env bash
    set -euo pipefail
    NS="{{ NAMESPACE }}"
    CONSUL_POD="consul-server-0"
    CONSUL_ADDR="http://127.0.0.1:8500"

    put_kv() {
      local key="$1" value="$2"
      echo "  Setting ${key}"
      kubectl exec "$CONSUL_POD" -n "$NS" -- \
        curl -sf -X PUT -d "$value" "${CONSUL_ADDR}/v1/kv/${key}" > /dev/null
    }

    # Read values from Helm release
    VALUES=$(helm get values {{ RELEASE }} -n "$NS" -o json 2>/dev/null)
    PG_PASS=$(echo "$VALUES" | jq -r '.postgresql.auth.postgresPassword // "postgres"')
    PG_DB=$(echo "$VALUES"   | jq -r '.postgresql.auth.database // "rara"')
    MINIO_USER=$(echo "$VALUES" | jq -r '.minio.rootUser // "minioadmin"')
    MINIO_PASS=$(echo "$VALUES" | jq -r '.minio.rootPassword // "minioadmin"')

    echo "Seeding Consul KV via ${CONSUL_POD} ..."

    # Database
    put_kv "rara/config/database/database_url" \
      "postgres://postgres:${PG_PASS}@{{ RELEASE }}-postgresql:5432/${PG_DB}"

    # Object store (MinIO)
    put_kv "rara/config/object_store/endpoint"          "http://{{ RELEASE }}-minio:9000"
    put_kv "rara/config/object_store/access_key_id"     "${MINIO_USER}"
    put_kv "rara/config/object_store/secret_access_key" "${MINIO_PASS}"
    put_kv "rara/config/object_store/bucket"            "rara"

    # Memory (ChromaDB)
    put_kv "rara/config/memory/chroma_url" "http://{{ RELEASE }}-chromadb:8000"

    # Memory (Mem0 REST API) — only if enabled
    MEM0_ENABLED=$(echo "$VALUES" | jq -r '.mem0.enabled // false')
    if [ "$MEM0_ENABLED" = "true" ]; then
      put_kv "rara/config/memory/mem0_base_url" "http://{{ RELEASE }}-mem0:8000"
    fi

    # Memory (Memos note service) — only if enabled
    MEMOS_ENABLED=$(echo "$VALUES" | jq -r '.memos.enabled // false')
    if [ "$MEMOS_ENABLED" = "true" ]; then
      put_kv "rara/config/memory/memos_base_url" "http://{{ RELEASE }}-memos:5230"
      MEMOS_TOKEN=$(echo "$VALUES" | jq -r '.consulSeed.overrides.memosToken // empty')
      if [ -n "$MEMOS_TOKEN" ]; then put_kv "rara/config/memory/memos_token" "$MEMOS_TOKEN"; fi
    fi

    # Memory (Hindsight 4-network) — only if enabled
    HINDSIGHT_ENABLED=$(echo "$VALUES" | jq -r '.hindsight.enabled // false')
    if [ "$HINDSIGHT_ENABLED" = "true" ]; then
      put_kv "rara/config/memory/hindsight_base_url" "http://{{ RELEASE }}-hindsight:8888"
      HINDSIGHT_BANK_ID=$(echo "$VALUES" | jq -r '.consulSeed.overrides.hindsightBankId // "default"')
      put_kv "rara/config/memory/hindsight_bank_id" "$HINDSIGHT_BANK_ID"
    fi

    # Crawl4AI
    put_kv "rara/config/crawl4ai/base_url" "http://{{ RELEASE }}-crawl4ai:11235"

    # Langfuse (LLM observability)
    put_kv "rara/config/langfuse/host" "http://{{ RELEASE }}-langfuse-web:3000"
    LF_PK=$(echo "$VALUES" | jq -r '.consulSeed.langfuse.publicKey // empty')
    LF_SK=$(echo "$VALUES" | jq -r '.consulSeed.langfuse.secretKey // empty')
    if [ -n "$LF_PK" ]; then put_kv "rara/config/langfuse/public_key" "$LF_PK"; fi
    if [ -n "$LF_SK" ]; then put_kv "rara/config/langfuse/secret_key" "$LF_SK"; fi

    echo "✔ Consul KV seed complete"

[doc("list all Consul KV keys under rara/config/")]
[group("🔧 Consul")]
consul-keys:
    kubectl exec consul-server-0 -n {{ NAMESPACE }} -- \
      curl -sf http://127.0.0.1:8500/v1/kv/rara/config/?keys 2>/dev/null | jq .

# --------------------------------------------------------------------------
# Doctor — Infrastructure health check
# --------------------------------------------------------------------------

[doc("export CA cert and trust it in macOS keychain (requires sudo)")]
[group("🩺 Doctor")]
trust-ca:
    #!/usr/bin/env bash
    set -euo pipefail
    CA_FILE="/tmp/rara-infra-ca.crt"
    kubectl get secret rara-infra-ca-tls -n {{ NAMESPACE }} -o jsonpath='{.data.ca\.crt}' | base64 -d > "$CA_FILE"
    echo "Exported CA certificate to $CA_FILE"
    sudo security add-trusted-cert -d -r trustRoot -k /Library/Keychains/System.keychain "$CA_FILE"
    echo "CA trusted in macOS keychain. Restart browser to take effect."

[doc("add *.rara.local entries to /etc/hosts (requires sudo)")]
[group("🩺 Doctor")]
hosts:
    #!/usr/bin/env bash
    set -euo pipefail
    LB_IP=$(kubectl get svc {{ RELEASE }}-traefik -n {{ NAMESPACE }} -o jsonpath='{.status.loadBalancer.ingress[0].ip}' 2>/dev/null)
    if [ -z "$LB_IP" ]; then echo "ERROR: Traefik LoadBalancer IP not found"; exit 1; fi
    DOMAIN=$(helm get values {{ RELEASE }} -n {{ NAMESPACE }} -o json 2>/dev/null | jq -r '.global.domain // "rara.local"')
    SERVICES="grafana prometheus alertmanager langfuse quickwit consul minio traefik tempo memos hindsight"
    HOSTS_LINE="${LB_IP}  $(for s in $SERVICES; do printf "%s.${DOMAIN} " "$s"; done)"
    MARKER="# rara-infra managed"
    # Remove old entries
    if grep -q "$MARKER" /etc/hosts 2>/dev/null; then
      sudo sed -i '' "/$MARKER/d" /etc/hosts
    fi
    echo "${HOSTS_LINE} ${MARKER}" | sudo tee -a /etc/hosts > /dev/null
    echo "Added to /etc/hosts:"
    grep "$MARKER" /etc/hosts

[doc("check infrastructure health across all components")]
[group("🩺 Doctor")]
doctor:
    #!/usr/bin/env bash
    set -euo pipefail
    NS="{{ NAMESPACE }}"
    PASS="\033[32m✔\033[0m"
    FAIL="\033[31m✘\033[0m"
    WARN="\033[33m⚠\033[0m"
    SKIP="\033[90m–\033[0m"
    ok=0; fail=0; skip=0

    check() {
      local name="$1"; shift
      if result=$("$@" 2>&1); then
        printf " ${PASS}  %-28s %s\n" "$name" "$result"
        ok=$((ok + 1))
      else
        printf " ${FAIL}  %-28s %s\n" "$name" "$result"
        fail=$((fail + 1))
      fi
    }

    check_pod_ready() {
      local name="$1" selector="$2"
      local line
      line=$(kubectl get pods -n "$NS" -l "$selector" --no-headers 2>/dev/null | head -1)
      if [ -z "$line" ]; then
        printf " ${SKIP}  %-28s %s\n" "$name" "no pods found"
        skip=$((skip + 1)); return
      fi
      local ready status
      ready=$(echo "$line" | awk '{print $2}')
      status=$(echo "$line" | awk '{print $3}')
      if [ "$status" = "Running" ]; then
        printf " ${PASS}  %-28s %s\n" "$name" "$ready $status"
        ok=$((ok + 1))
      else
        printf " ${FAIL}  %-28s %s\n" "$name" "$ready $status"
        fail=$((fail + 1))
      fi
    }

    check_endpoint() {
      local name="$1" svc="$2" port="$3" path="${4:-/}"
      if kubectl get svc "$svc" -n "$NS" &>/dev/null; then
        local code
        code=$(kubectl exec deploy/"$(kubectl get deploy -n "$NS" -o jsonpath='{.items[0].metadata.name}' 2>/dev/null)" \
          -n "$NS" -- curl -s -o /dev/null -w '%{http_code}' "http://${svc}:${port}${path}" 2>/dev/null || echo "000")
        if [[ "$code" =~ ^[23] ]]; then
          printf " ${PASS}  %-28s %s\n" "$name" "HTTP $code"
          ok=$((ok + 1))
        else
          printf " ${FAIL}  %-28s %s\n" "$name" "HTTP $code"
          fail=$((fail + 1))
        fi
      else
        printf " ${SKIP}  %-28s %s\n" "$name" "service not found"
        skip=$((skip + 1))
      fi
    }

    echo ""
    echo "🩺 rara-infra doctor — namespace: $NS"
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"

    # -- Helm release --
    echo ""
    echo "📦 Helm Release"
    check "release deployed" bash -c "helm status {{ RELEASE }} -n $NS -o json 2>/dev/null | jq -r '.info.status'"

    # -- Core infra --
    echo ""
    echo "🗄️  Core Infrastructure"
    check_pod_ready "PostgreSQL"     "app.kubernetes.io/name=postgresql"
    check_pod_ready "MinIO"          "app=minio"
    check_pod_ready "ChromaDB"       "app.kubernetes.io/name=chromadb"
    check_pod_ready "Crawl4AI"       "app.kubernetes.io/name=crawl4ai"

    # -- Memory services --
    echo ""
    echo "🧠 Memory Services"
    check_pod_ready "Mem0"           "app.kubernetes.io/component=mem0"
    check_pod_ready "Memos"          "app.kubernetes.io/component=memos"
    check_pod_ready "Memos PG"       "app.kubernetes.io/component=memos-pg"
    check_pod_ready "Hindsight"      "app.kubernetes.io/component=hindsight"
    check_pod_ready "Hindsight PG"   "app.kubernetes.io/component=hindsight-pg"

    # -- Ingress & TLS --
    echo ""
    echo "🌐 Ingress & TLS"
    check_pod_ready "Traefik"        "app.kubernetes.io/name=traefik"
    check_pod_ready "cert-manager"   "app.kubernetes.io/name=cert-manager"
    check "wildcard certificate" bash -c \
      "kubectl get certificate -n $NS -o jsonpath='{.items[?(@.spec.dnsNames[0]==\"*.rara.local\")].status.conditions[0].status}' 2>/dev/null | grep -q True && echo 'Ready' || echo 'Not Ready'"

    # -- Observability --
    echo ""
    echo "📈 Observability"
    check_pod_ready "Prometheus"     "app.kubernetes.io/name=prometheus"
    check_pod_ready "Grafana"        "app.kubernetes.io/name=grafana"
    check_pod_ready "AlertManager"   "app.kubernetes.io/name=alertmanager"
    check_pod_ready "Tempo"          "app.kubernetes.io/name=tempo"
    check_pod_ready "Alloy"          "app.kubernetes.io/name=alloy"
    check_pod_ready "Quickwit"       "app.kubernetes.io/name=quickwit"

    # -- Platform services --
    echo ""
    echo "🔧 Platform Services"
    check_pod_ready "Langfuse Web"   "app=web,app.kubernetes.io/name=langfuse"
    check_pod_ready "Langfuse Worker" "app=worker,app.kubernetes.io/name=langfuse"
    check_pod_ready "Langfuse PG"    "statefulset.kubernetes.io/pod-name=rara-infra-langfuse-pg-0"
    check_pod_ready "Redis"          "app.kubernetes.io/name=redis"
    check_pod_ready "Consul Server"  "app=consul,component=server"
    check_pod_ready "Consul Client"  "app=consul,component=client"
    check "Consul KV (rara/config/)" bash -c \
      "count=\$(kubectl exec {{ RELEASE }}-consul-server-0 -n $NS -- \
        curl -sf http://127.0.0.1:8500/v1/kv/rara/config/?keys 2>/dev/null | jq '. | length'); \
       if [ \"\$count\" -gt 0 ] 2>/dev/null; then echo \"\${count} keys\"; else echo 'no keys found'; false; fi"

    # -- PVCs --
    echo ""
    echo "💾 Persistent Volumes"
    check "PVC status" bash -c \
      "total=\$(kubectl get pvc -n $NS --no-headers 2>/dev/null | wc -l | tr -d ' '); \
       bound=\$(kubectl get pvc -n $NS --no-headers 2>/dev/null | grep -c Bound || true); \
       echo \"\${bound}/\${total} Bound\""

    # -- Endpoints --
    DOMAIN=$(helm get values {{ RELEASE }} -n "$NS" -o json 2>/dev/null | jq -r '.global.domain // "rara.local"')
    LB_IP=$(kubectl get svc {{ RELEASE }}-traefik -n "$NS" -o jsonpath='{.status.loadBalancer.ingress[0].ip}' 2>/dev/null || echo "pending")
    echo ""
    echo "🔗 Endpoints (https://*.${DOMAIN}  LB: ${LB_IP})"
    for svc in grafana prometheus alertmanager langfuse quickwit consul minio traefik memos hindsight; do
      url="https://${svc}.${DOMAIN}"
      code=$(curl -skL --noproxy "*" --max-time 5 --resolve "${svc}.${DOMAIN}:443:${LB_IP}" -o /dev/null -w '%{http_code}' "$url" 2>/dev/null || echo "000")
      if [[ "$code" =~ ^[23] ]]; then
        printf " ${PASS}  %-28s %s\n" "$svc" "$url  (HTTP $code)"
        ok=$((ok + 1))
      else
        printf " ${FAIL}  %-28s %s\n" "$svc" "$url  (HTTP $code)"
        fail=$((fail + 1))
      fi
    done

    # -- Summary --
    echo ""
    echo "━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━━"
    printf "  ✔ %d passed" "$ok"
    if [ "$fail" -gt 0 ]; then printf "  ✘ %d failed" "$fail"; fi
    if [ "$skip" -gt 0 ]; then printf "  – %d skipped" "$skip"; fi
    echo ""
    if [ "$fail" -gt 0 ]; then exit 1; else exit 0; fi
