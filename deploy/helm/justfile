CHART := "rara-infra"
RELEASE := env("HELM_RELEASE", "rara-infra")
NAMESPACE := env("HELM_NAMESPACE", "rara")
VALUES_DEV := "rara-infra/values-dev.yaml"

[group("📒 Help")]
[private]
default:
    @just --list --list-heading '⎈ helm justfile:\n'

# --------------------------------------------------------------------------
# Dependencies
# --------------------------------------------------------------------------

[doc("download / update subchart dependencies")]
[group("📦 Dependencies")]
deps:
    helm dependency build {{ CHART }}

[doc("list current subchart dependency versions")]
[group("📦 Dependencies")]
deps-list:
    helm dependency list {{ CHART }}

[doc("update subchart dependencies to latest allowed versions")]
[group("📦 Dependencies")]
deps-update:
    helm dependency update {{ CHART }}

# --------------------------------------------------------------------------
# Validate
# --------------------------------------------------------------------------

[doc("lint chart with default values")]
[group("✅ Validate")]
lint:
    helm lint {{ CHART }}

[doc("lint chart with dev overlay")]
[group("✅ Validate")]
lint-dev:
    helm lint {{ CHART }} -f {{ VALUES_DEV }}

[doc("render templates locally (dry-run)")]
[group("✅ Validate")]
template:
    helm template {{ RELEASE }} {{ CHART }}

[doc("render templates with dev overlay")]
[group("✅ Validate")]
template-dev:
    helm template {{ RELEASE }} {{ CHART }} -f {{ VALUES_DEV }}

[doc("diff upcoming changes against live release")]
[group("✅ Validate")]
diff *ARGS:
    helm diff upgrade {{ RELEASE }} {{ CHART }} -n {{ NAMESPACE }} {{ ARGS }}

# --------------------------------------------------------------------------
# Install / Upgrade / Uninstall
# --------------------------------------------------------------------------

[doc("install chart (production values, server-side apply)")]
[group("🚀 Deploy")]
install:
    helm install {{ RELEASE }} {{ CHART }} -n {{ NAMESPACE }} --create-namespace --server-side

[doc("install chart (dev values, server-side apply)")]
[group("🚀 Deploy")]
install-dev:
    helm install {{ RELEASE }} {{ CHART }} -n {{ NAMESPACE }} --create-namespace --server-side -f {{ VALUES_DEV }}

[doc("upgrade existing release (server-side apply)")]
[group("🚀 Deploy")]
upgrade *ARGS:
    helm upgrade {{ RELEASE }} {{ CHART }} -n {{ NAMESPACE }} --server-side {{ ARGS }}

[doc("upgrade with dev overlay (server-side apply)")]
[group("🚀 Deploy")]
upgrade-dev *ARGS:
    helm upgrade {{ RELEASE }} {{ CHART }} -n {{ NAMESPACE }} --server-side -f {{ VALUES_DEV }} {{ ARGS }}

[doc("upgrade with rollback on failure")]
[group("🚀 Deploy")]
upgrade-safe *ARGS:
    helm upgrade {{ RELEASE }} {{ CHART }} -n {{ NAMESPACE }} --server-side --rollback-on-failure {{ ARGS }}

[doc("uninstall release")]
[group("🚀 Deploy")]
uninstall:
    helm uninstall {{ RELEASE }} -n {{ NAMESPACE }}

