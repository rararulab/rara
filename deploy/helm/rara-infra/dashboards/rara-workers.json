{
  "uid": "rara-workers",
  "title": "Rara Workers",
  "tags": ["rara", "workers"],
  "timezone": "browser",
  "schemaVersion": 39,
  "version": 1,
  "refresh": "10s",
  "time": { "from": "now-1h", "to": "now" },
  "panels": [
    {
      "id": 1,
      "title": "Worker Execution Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(worker_executions_total[5m])) by (worker)",
          "legendFormat": "{{worker}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "id": 2,
      "title": "Worker Error Rate",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(worker_errors_total[5m])) by (worker)",
          "legendFormat": "{{worker}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "id": 3,
      "title": "Worker Execution Duration (p95)",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 0 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "histogram_quantile(0.95, sum(rate(worker_execution_duration_seconds_bucket[5m])) by (le, worker))",
          "legendFormat": "{{worker}} p95",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "s" }
      }
    },
    {
      "id": 4,
      "title": "Worker Active Status",
      "type": "stat",
      "gridPos": { "h": 8, "w": 8, "x": 0, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "worker_active",
          "legendFormat": "{{worker}}",
          "refId": "A"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "mappings": [
            { "type": "value", "options": { "0": { "text": "Stopped", "color": "red" }, "1": { "text": "Active", "color": "green" } } }
          ]
        }
      }
    },
    {
      "id": 5,
      "title": "Worker Start/Stop Events",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 8, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(worker_started_total[5m])) by (worker)",
          "legendFormat": "{{worker}} started",
          "refId": "A"
        },
        {
          "expr": "sum(rate(worker_stopped_total[5m])) by (worker)",
          "legendFormat": "{{worker}} stopped",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    },
    {
      "id": 6,
      "title": "Worker Pause/Resume",
      "type": "timeseries",
      "gridPos": { "h": 8, "w": 8, "x": 16, "y": 8 },
      "datasource": { "type": "prometheus", "uid": "prometheus" },
      "targets": [
        {
          "expr": "sum(rate(worker_paused_total[5m])) by (worker)",
          "legendFormat": "{{worker}} paused",
          "refId": "A"
        },
        {
          "expr": "sum(rate(worker_resumed_total[5m])) by (worker)",
          "legendFormat": "{{worker}} resumed",
          "refId": "B"
        }
      ],
      "fieldConfig": {
        "defaults": { "unit": "ops" }
      }
    }
  ]
}
