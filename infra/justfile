[private]
default:
    @just --list --list-heading 'infra justfile:\n'

[doc("build rara CLI binary")]
build:
    go build -o bin/rara ./cmd

# ========================================================================================
# Kind — local dev environment (requires Docker only)
# ========================================================================================

[doc("spin up a complete rara stack in a local kind cluster")]
kind-up *ARGS:
    go run ./cmd setup up {{ ARGS }}

[doc("tear down the kind cluster and clean up /etc/hosts")]
kind-down *ARGS:
    go run ./cmd setup down {{ ARGS }}

[doc("show status of the local kind environment")]
kind-status *ARGS:
    go run ./cmd setup status {{ ARGS }}

[doc("re-seed Consul KV with rara config")]
kind-seed *ARGS:
    go run ./cmd setup seed {{ ARGS }}

[doc("update /etc/hosts for *.rara.local resolution")]
kind-hosts *ARGS:
    go run ./cmd setup hosts add {{ ARGS }}

# ========================================================================================
# Pulumi
# ========================================================================================

[doc("initialize Pulumi stacks (run once)")]
init:
    pulumi login --local && pulumi stack init infra-dev && pulumi stack init app-dev

[doc("deploy infrastructure stack")]
infra-up:
    pulumi up -s infra-dev -y

[doc("preview infrastructure changes")]
infra-preview:
    pulumi preview -s infra-dev

[doc("destroy infrastructure stack")]
infra-destroy:
    pulumi destroy -s infra-dev -y

[doc("deploy application stack")]
app-up:
    pulumi up -s app-dev -y

[doc("preview application changes")]
app-preview:
    pulumi preview -s app-dev

[doc("destroy application stack")]
app-destroy:
    pulumi destroy -s app-dev -y

[doc("deploy infra + app stacks")]
setup: infra-up app-up

[doc("destroy app + infra stacks")]
destroy: app-destroy infra-destroy
